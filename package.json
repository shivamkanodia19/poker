{
  "name": "poker-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build:app": "vite build",
    "preview": "vite preview",
    "lint": "eslint app src",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:dist": "node scripts/verify-dist.mjs",
    "verify": "npm run typecheck && npm run test && npm run build && npm run test:dist"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.27.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.32.1",
    "vite": "^5.4.21",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "motion": "^12.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
